exports[`generated Codex config snapshots (§21.1) > patches into a config with a same-event user PostToolUse hook + other keys 1`] = `
"model = "o3"
approval_policy = "on-request"
notify = [ "birdybeep", "hook", "codex" ]

[sandbox]
mode = "workspace-write"

