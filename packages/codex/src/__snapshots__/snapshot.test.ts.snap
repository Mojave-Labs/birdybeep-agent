command = "birdybeep hook codex"
timeout = 10

[[hooks.SubagentStart]]
matcher = ""

[[hooks.SubagentStart.hooks]]
type = "command"
command = "birdybeep hook codex"
timeout = 10

[[hooks.SubagentStop]]
matcher = ""

[[hooks.SubagentStop.hooks]]
type = "command"
command = "birdybeep hook codex"
timeout = 10
"
`;

