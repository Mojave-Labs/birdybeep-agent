{
  "name": "@birdybeep/cli",
  "version": "0.0.3",
  "description": "The BirdyBeep CLI — pair your machine, install agent adapters, and stream coding-agent lifecycle events to BirdyBeep.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mojave-Labs/birdybeep-agent.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "birdybeep": "./dist/bin.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@birdybeep/agent-core": "workspace:*",
    "@birdybeep/claude-code": "workspace:*",
    "@birdybeep/codex": "workspace:*",
    "@birdybeep/opencode": "workspace:*",
    "uqr": "0.1.2"
  },
  "devDependencies": {
    "@birdybeep/test-harness": "workspace:*"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
