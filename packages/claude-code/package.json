{
  "name": "@birdybeep/claude-code",
  "version": "0.0.0",
  "description": "BirdyBeep adapter for Claude Code: hook templates, non-destructive config install/uninstall, and event normalization.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mojave-Labs/birdybeep-agent.git",
    "directory": "packages/claude-code"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@birdybeep/agent-core": "workspace:*"
  },
  "devDependencies": {
    "@birdybeep/test-harness": "workspace:*"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
