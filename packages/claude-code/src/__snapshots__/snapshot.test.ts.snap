          {
            "type": "command",
            "command": "birdybeep hook claude",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "birdybeep hook claude",
            "timeout": 10
          }
        ]
      }
    ],
    "StopFailure": [
