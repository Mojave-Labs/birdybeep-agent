{
  "name": "birdybeep-agent",
  "version": "0.0.0",
  "private": true,
  "description": "Public, MIT-licensed BirdyBeep CLI (@birdybeep/cli) + Claude Code / Codex / OpenCode agent adapters.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
